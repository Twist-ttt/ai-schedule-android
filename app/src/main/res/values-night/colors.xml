<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== Glassmorphism 设计令牌（夜间 / values-night） ===== -->
    <!-- 深邃靛蓝渐变保留；霜与描边同步加厚，衬托近白文字 -->

    <!-- 状态栏背景：实色（= 渐变顶端深靛），让顶部系统栏与 ActionBar 标题物理分离 -->
    <color name="glass_status_bar">#FF1B1538</color>

    <!-- 深邃靛蓝渐变，衬托白色玻璃面板 -->
    <color name="glass_grad_start">#FF1B1538</color>
    <color name="glass_grad_center">#FF2A2466</color>
    <color name="glass_grad_end">#FF3D2A8E</color>

    <!-- 背景柔光斑：深底上的微亮光晕（靛/蓝/青），给玻璃提供"被磨砂"的彩色底 -->
    <color name="glass_blob_lavender">#336366F1</color>
    <color name="glass_blob_sky">#265B8DFF</color>
    <color name="glass_blob_mint">#1F2DD4BF</color>

    <!-- 卡片柔和投影色（夜间深靛，避免亮边） -->
    <color name="glass_shadow_spot">#FF1E1B4B</color>
    <color name="glass_shadow_ambient">#FF312E81</color>

    <!-- 玻璃面板：深霜（50%）+ 微白描边（60%）+ 顶部微光，白字落其上清晰 -->
    <color name="glass_card_fill">#80222A52</color>
    <color name="glass_card_stroke">#99FFFFFF</color>
    <color name="glass_card_stroke_focused">#B3A5B4FC</color>

    <!-- 玻璃输入区：比面板更透（35%）+ 40% 白描边 -->
    <color name="glass_input_fill">#59FFFFFF</color>
    <color name="glass_input_stroke">#66FFFFFF</color>
    <!-- 玻璃顶部光泽渐变起点：夜间弱化 -->
    <color name="glass_highlight_top">#33FFFFFF</color>

    <!-- 文本：近白色系 -->
    <color name="glass_text_primary">#FFF1F5F9</color>
    <color name="glass_text_secondary">#FFCBD5E1</color>
    <color name="glass_text_hint">#FF94A3B8</color>

    <!-- 强调色：夜下调亮以保证对比 -->
    <color name="glass_accent">#FFA5B4FC</color>
    <color name="glass_accent_teal">#FF2DD4BF</color>

    <!-- 按钮填充：略亮的靛蓝，白字可读 -->
    <color name="glass_btn_primary">#FF6366F1</color>
    <color name="glass_btn_primary_variant">#FF818CF8</color>

    <!-- 玻璃二级按钮：深底上的霜（20%）+ 50% 白描边，明显低于输入框 -->
    <color name="glass_btn_glass_fill">#33FFFFFF</color>
    <color name="glass_btn_glass_stroke">#80FFFFFF</color>

    <color name="glass_icon_on_gradient">#FFFFFFFF</color>

    <!-- 顶部 ActionBar：半透明深色条（60%），配白字与白图标 -->
    <color name="glass_appbar_bg">#99000000</color>
    <!-- ActionBar 底部分隔线 -->
    <color name="glass_appbar_divider">#33FFFFFF</color>
</resources>
