<?xml version="1.0" encoding="utf-8"?>
<!-- 玻璃输入框：聚焦时描边加亮加粗，强化反馈 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_card_fill" />
            <stroke
                android:width="1.5dp"
                android:color="@color/glass_card_stroke_focused" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_card_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_card_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
