<?xml version="1.0" encoding="utf-8"?>
<!-- 解析历史列表项：玻璃卡片，展示 原句 / JSON / 元信息 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.MyApp.GlassContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="6dp"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        style="@style/TextAppearance.MyApp.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history_label_input" />

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/glass_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        style="@style/TextAppearance.MyApp.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/history_label_json" />

    <TextView
        android:id="@+id/tvJson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="monospace"
        android:maxLines="6"
        android:textColor="@color/glass_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/glass_text_hint"
        android:textSize="11sp" />
</LinearLayout>
