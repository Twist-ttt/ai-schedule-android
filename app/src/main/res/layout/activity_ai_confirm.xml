<?xml version="1.0" encoding="utf-8"?>
<!-- AI 确认页：玻璃 Toolbar + 原始输入引用块 + 玻璃表单 + 保存 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_appbar"
        app:elevation="0dp"
        app:title="@string/confirm_title"
        app:titleTextColor="@color/glass_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 原始输入：玻璃引用块（仅 AI 模式显示；手动填写隐藏） -->
            <LinearLayout
                android:id="@+id/sourceBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/field_source" />

                <TextView
                    android:id="@+id/tvSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_glass_input"
                    android:minHeight="52dp"
                    android:padding="14dp"
                    android:textColor="@color/glass_text_secondary"
                    android:textColorHint="@color/glass_text_hint"
                    android:textIsSelectable="true"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 表单玻璃面板 -->
            <LinearLayout
                style="@style/Widget.MyApp.GlassContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_title" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/field_title"
                    android:inputType="text" />

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/field_date" />

                <EditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:hint="@string/field_datetime_hint"
                    android:inputType="none"
                    android:longClickable="false" />

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/field_time" />

                <EditText
                    android:id="@+id/etTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:hint="@string/field_datetime_hint"
                    android:inputType="none"
                    android:longClickable="false" />

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/field_location" />

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/field_location"
                    android:inputType="text" />

                <TextView
                    style="@style/TextAppearance.MyApp.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/field_reminder" />

                <EditText
                    android:id="@+id/etReminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/field_reminder"
                    android:inputType="number" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/action_save" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
