<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Glassmorphism 主题：渐变穿透窗口 / 透明状态栏 / 玻璃 ActionBar / 玻璃控件 -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- 窗口背景：全屏渐变 -->
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>

        <!-- 状态栏透明 + 白色图标，渐变穿透至顶部 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- 关闭 Android 15+ 强制 edge-to-edge，避免内容侵入状态栏 -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>

        <!-- 主色（按钮 / FAB / 选中态） -->
        <item name="colorPrimary">@color/glass_btn_primary</item>
        <item name="colorPrimaryVariant">@color/glass_btn_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/glass_accent_teal</item>
        <item name="colorSecondaryVariant">@color/glass_accent_teal</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- 默认文本色 -->
        <item name="android:textColorPrimary">@color/glass_text_primary</item>
        <item name="android:textColorSecondary">@color/glass_text_secondary</item>
        <item name="android:textColorHint">@color/glass_text_hint</item>

        <!-- ActionBar：透明玻璃条 -->
        <item name="actionBarStyle">@style/Widget.MyApp.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.MyApp.ActionBar</item>

        <!-- 控件默认样式：玻璃输入框 / 玻璃主按钮 -->
        <item name="editTextStyle">@style/Widget.MyApp.EditText</item>
        <item name="materialButtonStyle">@style/Widget.MyApp.Button</item>
    </style>
</resources>
