<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 保留旧色，避免破坏既有引用 -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- ===== Glassmorphism 设计令牌（白天 / values） ===== -->
    <!-- 偏淡粉彩雾色系：低饱和、高明度，让白霜玻璃面板自然浮起 -->

    <!-- 状态栏背景：实色（= 渐变顶端色），让顶部系统栏与 ActionBar 标题物理分离，避免重叠 -->
    <color name="glass_status_bar">#FFEEF2FF</color>

    <!-- 全屏渐变背景：淡薰衣草 → 淡天蓝 → 淡粉白（偏淡，非高饱和品牌色） -->
    <color name="glass_grad_start">#FFEEF2FF</color>
    <color name="glass_grad_center">#FFE0F2FE</color>
    <color name="glass_grad_end">#FFFDF4FF</color>

    <!-- 背景柔光斑：玻璃面板"被磨砂"的彩色底；半透明，由 radial gradient 渲染为模糊光晕 -->
    <color name="glass_blob_lavender">#40B8A7FF</color>
    <color name="glass_blob_sky">#338FD8FF</color>
    <color name="glass_blob_mint">#24A7F3D0</color>

    <!-- 卡片柔和投影色（API28+ outlineSpot/AmbientShadowColor 用；pre-28 忽略） -->
    <color name="glass_shadow_spot">#FF465AB4</color>
    <color name="glass_shadow_ambient">#FF6C7BD8</color>

    <!-- 玻璃面板：半透明白霜（55%，透出淡彩底与光斑）+ 纯白高光描边 + 顶部光泽层 -->
    <color name="glass_card_fill">#8CFFFFFF</color>
    <color name="glass_card_stroke">#FFFFFFFF</color>
    <color name="glass_card_stroke_focused">#B36C63FF</color>

    <!-- 玻璃输入区：比面板更透（40%），落在面板内呈"内陷"层次；描边 55% 白 -->
    <color name="glass_input_fill">#66FFFFFF</color>
    <color name="glass_input_stroke">#8CFFFFFF</color>
    <!-- 玻璃顶部光泽渐变起点：模拟毛玻璃顶光，增强立体感 -->
    <color name="glass_highlight_top">#66FFFFFF</color>

    <!-- 文本：深岩色系，落在白霜玻璃上高对比可读 -->
    <color name="glass_text_primary">#FF1E293B</color>
    <color name="glass_text_secondary">#FF475569</color>
    <color name="glass_text_hint">#FF64748B</color>

    <!-- 强调色：靛蓝（标签/聚焦态/图标）+ 青（提醒，沿用原有 teal 语感） -->
    <color name="glass_accent">#FF4F46E5</color>
    <color name="glass_accent_teal">#FF0F8B8D</color>

    <!-- 实色按钮填充（colorPrimary）及其变体 -->
    <color name="glass_btn_primary">#FF4F46E5</color>
    <color name="glass_btn_primary_variant">#FF4338CA</color>

    <!-- 玻璃二级按钮：比面板更透（38%）的霜 + 65% 白描边，与卡片拉开层次 -->
    <color name="glass_btn_glass_fill">#61FFFFFF</color>
    <color name="glass_btn_glass_stroke">#A6FFFFFF</color>

    <!-- 浮于渐变之上的图标/标题颜色（保留语义；ActionBar 已改用 glass_text_* 自适应） -->
    <color name="glass_icon_on_gradient">#FFFFFFFF</color>

    <!-- 顶部 ActionBar：白霜玻璃条（70%），配深色标题与图标 -->
    <color name="glass_appbar_bg">#B3FFFFFF</color>
</resources>
