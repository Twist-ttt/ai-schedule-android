<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== 容器 ===== -->

    <!-- 通用玻璃面板：霜化背景 + 细描边 + 柔和投影（圆角由 drawable 提供） -->
    <style name="Widget.MyApp.GlassContainer" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:elevation">8dp</item>
        <!-- API28+ 柔和靛蓝投影，近似 glassmorphism 彩色软阴影（pre-28 自动忽略） -->
        <item name="android:outlineSpotShadowColor">@color/glass_shadow_spot</item>
        <item name="android:outlineAmbientShadowColor">@color/glass_shadow_ambient</item>
    </style>

    <!-- ===== 文本外观 ===== -->

    <style name="TextAppearance.MyApp.Label" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/glass_accent</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.MyApp.ActionBar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/glass_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ===== 输入框（默认 editTextStyle） ===== -->

    <style name="Widget.MyApp.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_glass_input</item>
        <item name="android:textColor">@color/glass_text_primary</item>
        <item name="android:textColorHint">@color/glass_text_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <!-- ===== 按钮 ===== -->

    <!-- 主按钮（实色强调 CTA，默认 materialButtonStyle） -->
    <style name="Widget.MyApp.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/glass_btn_primary_csl</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">6dp</item>
        <item name="android:insetBottom">6dp</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- 次按钮（透明玻璃描边） -->
    <style name="Widget.MyApp.Button.Glass" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/glass_text_primary</item>
        <item name="backgroundTint">@color/glass_btn_glass_csl</item>
        <item name="strokeColor">@color/glass_btn_glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">6dp</item>
        <item name="android:insetBottom">6dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ===== ActionBar：白霜/深色玻璃条（随昼夜）+ 自适应标题与图标 ===== -->

    <style name="Widget.MyApp.ActionBar" parent="Widget.MaterialComponents.Light.ActionBar.Solid">
        <item name="background">@color/glass_appbar_bg</item>
        <item name="android:background">@color/glass_appbar_bg</item>
        <item name="elevation">0dp</item>
        <item name="titleTextStyle">@style/TextAppearance.MyApp.ActionBar.Title</item>
    </style>

    <!-- ActionBar 主题叠加：标题与图标颜色随昼夜自适应（白天深色 / 夜间白色） -->
    <style name="ThemeOverlay.MyApp.ActionBar" parent="ThemeOverlay.MaterialComponents.ActionBar">
        <item name="android:textColorPrimary">@color/glass_text_primary</item>
        <item name="colorControlNormal">@color/glass_text_primary</item>
    </style>
</resources>
